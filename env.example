# ============================================================
#  REQUIRED
# ============================================================
DISCORD_TOKEN=your-bot-token-here

# ============================================================
#  GENERAL  (all optional — defaults shown)
# ============================================================
PREFIX=*
DATA_FILE=./bot-data.json

# Delay (ms) before an empty temp VC is deleted
TEMP_VC_DELETE_DELAY_MS=500

# ============================================================
#  OWNER
# ============================================================
# Your Discord user ID — grants access to *servers and *leave commands.
# Right-click your profile in Discord → Copy User ID (needs Developer Mode on).
OWNER_ID=your-discord-user-id-here

# ============================================================
#  ANTISPAM / RATE LIMITER  (all optional — defaults shown)
# ============================================================
# Cooldown between any two commands from the same user (ms)
COOLDOWN_GENERAL=1500
# Cooldown for economy/gambling commands specifically (ms)
COOLDOWN_HEAVY=2500
# How many commands in the window before a temporary block kicks in
SPAM_THRESHOLD=6
# The sliding window these commands are counted over (ms)
SPAM_WINDOW_MS=8000
# How long a user is blocked after hitting the spam threshold (ms)
SPAM_BLOCK_MS=25000

# ============================================================
#  WELCOME DM  (optional)
# ============================================================
# Max concurrent DM sends at once
DM_QUEUE_CONCURRENCY=3

# Retry attempts per DM before giving up
DM_RETRY_MAX=3

# ============================================================
#  VC MILESTONE ROLES  (optional)
# ============================================================
# No env vars required — all config is done via *vcm commands in Discord.
# Time is tracked per-user per-guild and persisted to bot-data.json.
# The bot seeds sessions on startup for users already in VC.

# ============================================================
#  ECONOMY  (all optional — defaults shown)
# ============================================================
STARTING_BALANCE=500
DAILY_REWARD=2500
WORK_MIN=250
WORK_MAX=1200
BEG_MIN=25
BEG_MAX=350

# Cooldowns in milliseconds
WORK_COOLDOWN_MS=900000
BEG_COOLDOWN_MS=300000

# Max Smoke Bucks that can be bet in one game
MAX_BET=150000

# Max Smoke Bucks that can be donated per 24-hour window
DONATE_DAILY_LIMIT=250000

# ============================================================
#  DAILY QUESTS  (optional)
# ============================================================
# Timezone for daily quest reset (IANA tz name)
QUEST_RESET_TZ=America/Los_Angeles

# How many quests regular members get per day
REGULAR_QUESTS_PER_DAY=3

# How many quests server boosters get per day
BOOSTER_QUESTS_PER_DAY=5
